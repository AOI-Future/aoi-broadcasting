# === Stream Destinations (at least one required) ===
YOUTUBE_URL=rtmp://a.rtmp.youtube.com/live2
YOUTUBE_KEY=your-youtube-stream-key-here
KICK_URL=rtmps://your-kick-ingest-url:443/app
KICK_KEY=your-kick-stream-key-here

# === Viewer-side monitoring (used by watchdog) ===
YOUTUBE_WATCH_URL=https://youtube.com/live/your-watch-id
KICK_CHANNEL_URL=https://kick.com/your-channel

# === Archive (disabled by default for read-only music mounts) ===
# ARCHIVE_ENABLED=false

# === Loudness Normalization ===
NORMALIZE_MAX_FILES_PER_CYCLE=8
NORMALIZE_BOOTSTRAP_BATCH=50
NORMALIZE_DURING_STREAM_INTERVAL=120
NORMALIZE_TARGET_I=-16
NORMALIZE_TARGET_LRA=11
NORMALIZE_TARGET_TP=-1.5
NORMALIZE_NICE_LEVEL=10
FFMPEG_NORMALIZE_TIMEOUT=1800
FFMPEG_LOOP_PREENCODE_TIMEOUT=120

# === Playlist Chunking (new tracks reflected within minutes) ===
PLAYLIST_CHUNK_SIZE=5            # tracks per chunk (0=legacy full-playlist mode)
MUSIC_CHANGE_CHECK_INTERVAL=60   # seconds between directory scans
MUSIC_CHANGE_DEBOUNCE=60         # seconds to confirm change is stable

# === Stream Heartbeat ===
STREAM_HEARTBEAT_INTERVAL=120
